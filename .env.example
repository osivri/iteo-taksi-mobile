# Varsayılan development: yerel backend (scripts/start-dev.js LAN IP kullanır)
# EXPO_PUBLIC_API_URL=http://192.168.1.6:3001/api/v1

# Production/staging API'ye bağlanmak için:
# EXPO_PUBLIC_USE_REMOTE_API=true
# EXPO_PUBLIC_API_URL=https://iteo-taksi-backend-production.up.railway.app/api/v1

# Admin panel (production build için zorunlu)
# EXPO_PUBLIC_ADMIN_URL=https://admin.example.com/login

# EAS push bildirimleri
# EXPO_PUBLIC_EAS_PROJECT_ID=
